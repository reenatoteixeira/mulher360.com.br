---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { ebooks } from "../../data/ebooks";

const canonical = "https://mulher360.com.br/ebooks";
const title = "Mulher 360 | Ebooks";
const description = "Protocolos práticos da Mulher 360 para transformar seu corpo e sua rotina.";
const navigation = [{ label: "Voltar ao site", href: "/" }];
const footerLinks = [
  { label: "Sobre", href: "/#sobre" },
  { label: "Como funciona", href: "/#como-funciona" },
  { label: "Depoimentos", href: "/#depoimentos" },
  { label: "Abordagem", href: "/#metodologia" },
  { label: "Guias", href: "/ebooks" },
  { label: "Dúvidas", href: "/#faq" }
];
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <main id="top" class="overflow-x-clip">
    <SiteHeader navigation={navigation} compactNav />

    <section class="relative isolate pb-8 pt-24 sm:pb-10 sm:pt-28">
      <div class="floating-orb -left-12 top-12 h-32 w-32 bg-[#f2cc95]"></div>
      <div class="floating-orb right-0 top-28 h-40 w-40 bg-[#e8b17a]"></div>

      <div class="section-shell">
        <div class="fade-rise">
          <h1 class="mt-5 max-w-3xl text-[2.1rem] font-semibold leading-[0.95] sm:text-5xl">
            Protocolos práticos para transformar seu corpo e sua rotina.
          </h1>
          <p class="mt-4 max-w-2xl text-base leading-7 text-[color:var(--muted)] sm:text-lg">
            Escolha o material certo para o seu momento, entenda rapidamente a proposta de cada guia e avance para a página completa com um clique.
          </p>
        </div>
      </div>
    </section>

    <section id="catalogo" class="scroll-mt-28 pb-16 sm:scroll-mt-32 sm:pb-20">
      <div class="section-shell">
        <div class="mt-8 max-w-2xl">
          <label class="block sr-only text-sm font-semibold text-[color:var(--text)]" for="ebook-search">
            Buscar ebooks
          </label>
          <div class="mt-3 flex items-center gap-3 rounded-[1.6rem] border border-[rgba(143,63,22,0.12)] bg-[linear-gradient(180deg,rgba(255,255,255,0.82)_0%,rgba(255,248,244,0.92)_100%)] px-4 py-3 shadow-[0_18px_38px_rgba(60,33,19,0.08)] backdrop-blur">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[rgba(187,91,39,0.12)] text-[color:var(--primary-strong)]">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="9" cy="9" r="5.5" stroke="currentColor" stroke-width="1.8"></circle>
                <path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
              </svg>
            </span>
            <input
              id="ebook-search"
              type="search"
              placeholder="Busque por tema, objetivo ou nome do ebook"
              class="w-full border-0 bg-transparent p-0 text-sm text-[color:var(--text)] outline-none placeholder:text-[color:var(--muted)]"
            />
          </div>
        </div>

        <div id="catalog-grid" class="mt-8 grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
          {ebooks.map((ebook) => (
            <article
              class="section-card rounded-[1.9rem] p-4 sm:p-5"
              data-ebook-card
              data-search={ebook.searchTerms.join(" ")}
            >
              <div class="grid gap-5">
                <div class="overflow-hidden rounded-[1.55rem] border border-[color:var(--line)] bg-[rgba(255,255,255,0.34)] p-3">
                  <div class="relative w-full rounded-[1.55rem] border border-[color:var(--line)] bg-[#1f1512] p-3 shadow-[0_26px_52px_rgba(72,37,20,0.22)]">
                    <div class="rounded-[1.2rem] border border-white/10 bg-[linear-gradient(180deg,#18110f_0%,#30211c_38%,#bb5b27_100%)] px-5 py-6 text-white sm:px-6 sm:py-7">
                      <p class="text-[0.65rem] font-semibold uppercase tracking-[0.28em] text-[#f7d3ab]">{ebook.cover.brand}</p>
                      <h3 class="mt-6 font-display text-[2.15rem] font-semibold leading-none sm:text-[2.45rem]">
                        {ebook.cover.titleLine1}
                      </h3>
                      <h3 class="mt-1 font-display text-[2.15rem] font-semibold leading-none sm:text-[2.45rem]">
                        {ebook.cover.titleLine2}
                      </h3>
                      <p class="mt-4 text-sm leading-6 text-white/80">
                        {ebook.cover.subtitle}
                      </p>
                    </div>
                  </div>
                </div>

              <div class="px-1 pb-1">
                <div class="flex flex-col items-start gap-1 border-t border-[color:var(--line)] pt-4">
                  <span class="text-sm font-medium text-[color:var(--muted)] line-through sm:text-base">R${ebook.priceFrom}</span>
                  <span class="font-display text-[2.9rem] font-semibold leading-none text-[color:var(--primary-strong)] sm:text-[3.2rem]">R$ {ebook.priceTo}</span>
                </div>
                <div class="mt-5 flex flex-col gap-2.5">
                  <a class="cta-main offer-cta-primary" href={ebook.checkoutUrl}>Comprar agora</a>
                    <a class="cta-secondary" href={`/ebooks/${ebook.slug}`}>Ver detalhes</a>
                  </div>
                </div>
              </div>
            </article>
          ))}

          <div
            id="catalog-empty"
            class="section-card hidden min-h-[18rem] rounded-[2rem] items-center justify-center p-6 text-center text-base leading-7 text-[color:var(--muted)] sm:col-span-2 xl:col-span-3 sm:p-8"
          >
            <div class="max-w-xl">
              <p class="font-semibold text-[color:var(--text)]">Nenhum ebook encontrado.</p>
              <p class="mt-3">
                Tente buscar por outro tema, objetivo ou limpe a pesquisa para voltar a visualizar todos os ebooks disponíveis.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <SiteFooter links={footerLinks} />
  </main>

  <script is:inline>
    const searchInput = document.getElementById("ebook-search");
    const cards = Array.from(document.querySelectorAll("[data-ebook-card]"));
    const emptyState = document.getElementById("catalog-empty");
    const status = document.getElementById("catalog-status");

    if (searchInput instanceof HTMLInputElement) {
      const applyFilter = () => {
        const query = searchInput.value.trim().toLowerCase();
        let visibleCount = 0;

        cards.forEach((card) => {
          if (!(card instanceof HTMLElement)) return;
          const haystack = (card.dataset.search || "").toLowerCase();
          const matches = !query || haystack.includes(query);
          card.style.display = matches ? "" : "none";
          if (matches) visibleCount += 1;
        });

        if (emptyState instanceof HTMLElement) {
          emptyState.style.display = visibleCount === 0 ? "flex" : "none";
        }

        if (status instanceof HTMLElement) {
          status.textContent = query
            ? visibleCount === 0
              ? "Nenhum ebook corresponde ao termo buscado no momento."
              : `${visibleCount} ebook${visibleCount > 1 ? "s encontrados" : " encontrado"} para a busca atual.`
            : "Escolha um protocolo, abra os detalhes do material e avance para a página completa do ebook.";
        }
      };

      searchInput.addEventListener("input", applyFilter);
      applyFilter();
    }
  </script>
</BaseLayout>

---
interface LinkItem {
  label: string;
  href: string;
}

interface Props {
  links: LinkItem[];
}

const { links } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="site-footer border-t border-[color:var(--line)] bg-[rgba(47,31,26,0.96)] py-10 text-white">
  <div class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.95fr_1.55fr_0.9fr] lg:items-start">
      <div>
        <a class="inline-flex items-center no-underline" href="/" aria-label="Mulher 360">
          <img
            src="/favicon.svg"
            alt="Mulher 360"
            class="h-14 w-auto rounded-full bg-white/90 p-2"
            loading="lazy"
            decoding="async"
          />
        </a>
      </div>

      <div>
        <p class="text-lg font-semibold">Links rápidos</p>
        <div class="site-footer-links mt-4 grid gap-x-6 gap-y-3 text-sm text-white/72 sm:grid-cols-2 xl:grid-cols-3">
          {links.map((item) => (
            <a class="site-footer-link" href={item.href}>{item.label}</a>
          ))}
        </div>
      </div>

      <div>
        <p class="text-lg font-semibold">Contatos</p>
        <div class="mt-4 flex flex-wrap items-center gap-3">
          <a class="site-footer-icon" href="https://wa.me/5512988942652" aria-label="WhatsApp">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 20C16.418 20 20 16.642 20 12.5C20 8.358 16.418 5 12 5C7.582 5 4 8.358 4 12.5C4 13.91 4.415 15.227 5.135 16.353L4.25 19L7.067 18.152C8.415 19.31 10.13 20 12 20Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
              <path d="M10.2 9.55C10.4 9.1 10.52 9 10.78 9H11.08C11.2 9 11.31 9.07 11.38 9.17L11.95 10.05C12.04 10.19 12.03 10.37 11.92 10.5L11.43 11.07C11.35 11.16 11.34 11.3 11.4 11.4C11.79 12.03 12.34 12.57 12.97 12.96C13.07 13.02 13.2 13.01 13.3 12.93L13.86 12.45C14 12.34 14.18 12.32 14.32 12.41L15.2 12.98C15.3 13.05 15.37 13.16 15.37 13.28V13.58C15.37 13.84 15.27 13.96 14.83 14.16C14.57 14.28 14.27 14.28 14 14.18C12.55 13.63 11.39 12.47 10.84 11.02C10.74 10.75 10.74 10.45 10.86 10.19L10.2 9.55Z" fill="currentColor"></path>
            </svg>
          </a>
          <a class="site-footer-icon" href="https://www.instagram.com/mulher360_/" aria-label="Instagram">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="3.75" y="3.75" width="16.5" height="16.5" rx="4.25" stroke="currentColor" stroke-width="1.7"></rect>
              <circle cx="12" cy="12" r="3.75" stroke="currentColor" stroke-width="1.7"></circle>
              <circle cx="17.35" cy="6.65" r="1.1" fill="currentColor"></circle>
            </svg>
          </a>
          <a class="site-footer-icon" href="mailto:draluteixeira@gmail.com" aria-label="E-mail">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="3.5" y="5.5" width="17" height="13" rx="2.5" stroke="currentColor" stroke-width="1.7"></rect>
              <path d="M5 7L11.105 11.652C11.639 12.059 12.361 12.059 12.895 11.652L19 7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-8 border-t border-white/12 pt-6 text-center text-sm text-white/48">
      <p>CRN-3 89313 | Dra. Luciana Teixeira - Nutricionista | © {currentYear} Mulher 360™ - Todos os direitos reservados. </p>
    </div>
  </div>
</footer>
